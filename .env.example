# Biohacker App Environment Variables Template
# Copy to .env and fill in your values

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Lab PDF Extraction API (Production)
LAB_PDF_ENDPOINT=https://your-cloudflare-tunnel.trycloudflare.com/api/extract-lab-pdf
LAB_PDF_API_KEY=your_api_key_here

# BloodworkAI API Key (optional, leave empty if not using)
BLOODWORK_AI_API_KEY=
