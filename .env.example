# Biohacker App — Environment Variables Example
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Lab PDF extraction backend (must be HTTPS in production).
# Leave empty to disable PDF upload.
LAB_PDF_ENDPOINT=https://your-backend.example.com/api/extract-lab-pdf

# BloodworkAI API key (https://bloodworkai.com).
# Leave empty to disable the BloodworkAI service.
BLOODWORK_AI_API_KEY=your_bloodwork_ai_api_key_here
